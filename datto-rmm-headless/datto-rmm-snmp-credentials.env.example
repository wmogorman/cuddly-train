# Datto RMM headless SNMP credential creation
# Copy to datto-rmm-snmp-credentials.env and fill in values.

# Base URL of the Datto RMM web UI (no trailing slash)
DATTO_RMM_URL=https://zinfandel.rmm.datto.com

# Path to the plan CSV produced by datto-rmm-snmp-credential-plan.ps1
# Defaults to ./artifacts/datto-rmm/snmp-credential-plan.csv if omitted
# PLAN_CSV_PATH=./artifacts/datto-rmm/snmp-credential-plan.csv
